# Copy to .env and fill in. Never commit .env with secrets.

# Django (production)
# DJANGO_DEBUG=false
# DJANGO_SECRET_KEY=
# DJANGO_ALLOWED_HOSTS=your.domain.com,www.your.domain.com
# DJANGO_USE_X_FORWARDED=true
# CORS_ALLOWED_ORIGINS=https://your.domain.com
# CSRF_TRUSTED_ORIGINS=https://your.domain.com

# Database
# DB_NAME=waterwise
# DB_USER=postgres
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432

# Africa's Talking — real SMS from handsets
# Sandbox: AT_USERNAME=sandbox + test numbers only in the AT dashboard.
# Live: use your production app username (not "sandbox") and production API key.
# AT_USERNAME=
# AT_API_KEY=
# AT_SENDER_ID=ShortCodeOrAlphanumericId
#
# Incoming fault reports (structured SMS): set callback URL in AT dashboard to:
#   https://YOUR_DOMAIN/api/sms/incoming/
# Message format must match a water point in DB, e.g.: WP01 PUMP
#
# Legacy simple webhook (optional): https://YOUR_DOMAIN/webhook/sms/

# Android SMS gateway APK: when set, POST /api/sms/incoming/ must include header
#   X-SMS-Gateway-Secret: <same value>
# Send X-SMS-Gateway: 1 for JSON responses + SMS replies sent by the handset.
# SMS_GATEWAY_SHARED_SECRET=

# Email (SMTP for real delivery)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=noreply@your.domain.com
